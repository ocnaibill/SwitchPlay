# ==========================================
# SwitchPlay — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.
# ==========================================

# REQUIRED: Your Headscale server URL
TS_CONTROL_URL=https://your-headscale.example.com

# REQUIRED: A reusable pre-auth key generated from Headscale
# Generate one with: headscale preauthkeys create --reusable --expiration 365d --user <username>
TS_AUTH_KEY=hskey-auth-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: LAN Play server address in the tailnet (default: 100.64.0.2:11451)
# TS_LANPLAY_SERVER=100.64.0.2:11451
